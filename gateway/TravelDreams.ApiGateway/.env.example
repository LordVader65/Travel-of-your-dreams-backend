ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:${PORT}

Services__IdentidadUrl=<ms-identidad-url>
Services__AtraccionesUrl=<ms-atracciones-url>
Services__ReservasUrl=<ms-reservas-url>
Services__FacturacionUrl=<ms-facturacion-url>
Services__AuditoriaUrl=<ms-auditoria-url>

Gateway__EnableAuditLogging=true

JwtSettings__Issuer=TravelDreams
JwtSettings__Audience=TravelDreams.Clients
JwtSettings__SecretKey=<same-secret-as-ms-identidad>

BookingAuth__ClientId=booking-app
BookingAuth__ClientSecret=<booking-client-secret>
BookingAuth__Issuer=TravelDreams.BookingIntegration
BookingAuth__Audience=TravelDreams.Booking
BookingAuth__SecretKey=<booking-jwt-secret-min-32-chars>
BookingAuth__ExpirationMinutes=60

RabbitMqV3__Enabled=false
RabbitMqV3__Uri=
RabbitMqV3__UseTls=false
RabbitMqV3__Host=localhost
RabbitMqV3__Port=5672
RabbitMqV3__User=traveldreams
RabbitMqV3__Password=traveldreams123
RabbitMqV3__VirtualHost=/
RabbitMqV3__ExchangeName=traveldreams.marketplace.v3.events
RabbitMqV3__ReservasQueueName=q.v3.reservas.solicitudes
RabbitMqV3__FacturacionQueueName=q.v3.facturacion.solicitudes
RabbitMqV3__MarketplaceDebugQueueName=q.v3.marketplace.debug
RabbitMqV3__AuditoriaQueueName=q.v3.auditoria
RabbitMqV3__DeadLetterQueueName=q.v3.deadletter
MarketplaceV3__Enabled=false
