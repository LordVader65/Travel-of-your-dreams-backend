FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY . .
RUN dotnet publish services/ms-reservas/TravelDreams.MsReservas.Api/TravelDreams.MsReservas.Api.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app/publish .
ENV ASPNETCORE_Kestrel__EndpointDefaults__Protocols=Http1AndHttp2
EXPOSE 8080
ENTRYPOINT ["sh", "-c", "dotnet TravelDreams.MsReservas.Api.dll --urls http://0.0.0.0:${PORT:-8080}"]
